{
  "name": "benzene-typescript",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript port of Benzene, a middleware-based library supporting hexagonal (ports-and-adapters) architecture",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "src/*",
    "test/*"
  ],
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@opentelemetry/context-async-hooks": "^2.10.0",
    "@opentelemetry/sdk-metrics": "^2.10.0",
    "@opentelemetry/sdk-trace-base": "^2.10.0",
    "@types/node": "^26.1.1",
    "typescript": "^5.5.4",
    "vitest": "^2.1.9"
  }
}
